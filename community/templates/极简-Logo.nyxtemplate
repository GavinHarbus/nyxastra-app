{
  "body": "Minimal vector logo for {{brand_name}}, {{concept}} concept, geometric shapes, single-color {{accent_color}} on transparent background, balanced negative space, scalable.",
  "folderName": "Branding",
  "name": "极简 Logo",
  "parameterPreset": {
    "background": "transparent",
    "format": "png",
    "quality": "high",
    "size": {
      "height": 1024,
      "width": 1024
    }
  },
  "schema": "nyxtemplate",
  "tags": [
    "logo",
    "branding"
  ],
  "variables": [
    {
      "allowedValues": [],
      "defaultValue": "NyxAstra",
      "kind": "text",
      "name": "brand_name"
    },
    {
      "allowedValues": [],
      "defaultValue": "crescent moon over mountains",
      "kind": "text",
      "name": "concept"
    },
    {
      "allowedValues": [
        "deep indigo",
        "forest green",
        "amber",
        "crimson"
      ],
      "defaultValue": "deep indigo",
      "kind": "enumeration",
      "name": "accent_color"
    }
  ],
  "version": 2,
  "community": {
    "author": {
      "name": "Gavin Schnee",
      "url": "https://x.com/Alaric4678"
    },
    "license": "CC-BY-4.0",
    "category": "branding"
  },
  "cover": {
    "format": "png",
    "dataBase64": ""
  }
}
