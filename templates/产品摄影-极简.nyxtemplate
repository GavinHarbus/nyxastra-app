{
  "body": "Studio product photo of {{product}} on a seamless {{background_color}} backdrop, soft three-point lighting, crisp shadows, ultra sharp focus, commercial catalog style, centered composition.",
  "folderName": "Photo",
  "name": "产品摄影 · 极简",
  "parameterPreset": {
    "format": "png",
    "quality": "high",
    "size": {
      "height": 1024,
      "width": 1024
    }
  },
  "schema": "nyxtemplate",
