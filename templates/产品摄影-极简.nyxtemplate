    "product",
    "photo",
    "studio"
  ],
  "variables": [
    {
      "allowedValues": [],
      "defaultValue": "a matte black ceramic mug",
      "kind": "text",
      "name": "product"
    },
    {
      "allowedValues": [
        "warm cream",
        "deep charcoal",
        "soft grey",
        "stark white"
      ],
      "defaultValue": "warm cream",
      "kind": "enumeration",
      "name": "background_color"
    }
  ],
  "version": 2,
  "community": {
    "author": {
      "name": "Gavin Schnee",
