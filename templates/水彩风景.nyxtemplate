{
  "body": "Loose watercolor painting of {{scene}} during {{time_of_day}}, soft washes, visible paper texture, gentle pigment bleeds, muted complementary palette.",
  "folderName": "Illustration",
  "name": "水彩风景",
  "parameterPreset": {
    "format": "png",
    "quality": "high",
    "size": {
      "height": 1024,
      "width": 1536
    }
  },
  "schema": "nyxtemplate",
  "tags": [
    "watercolor",
    "landscape"
  ],
  "variables": [
    {
      "allowedValues": [],
      "defaultValue": "a quiet harbor with wooden boats",
      "kind": "text",
      "name": "scene"
    },
    {
      "allowedValues": [
        "early morning",
        "noon",
        "golden hour",
        "twilight"
      ],
      "defaultValue": "early morning",
      "kind": "enumeration",
      "name": "time_of_day"
    }
  ],
  "version": 2,
  "community": {
    "author": {
      "name": "Gavin Schnee",
      "url": "https://x.com/Alaric4678"
    },
    "license": "CC-BY-4.0",
    "category": "illustration"
  },
  "cover": {
    "format": "png",
    "dataBase64": ""
  },
  "sourceApp": "nyxastra-community"
}
