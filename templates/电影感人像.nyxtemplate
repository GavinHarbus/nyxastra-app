{
  "body": "A cinematic portrait of {{subject}}, {{mood}} mood, soft natural light, 85mm lens, shallow depth of field, ultra-detailed skin texture, color graded.",
  "folderName": "Photo",
  "name": "电影感人像",
  "parameterPreset": {
    "format": "png",
    "quality": "high",
    "size": {
      "height": 1536,
      "width": 1024
    }
  },
  "schema": "nyxtemplate",
  "tags": [
    "portrait",
    "photo"
  ],
  "variables": [
    {
      "allowedValues": [],
      "defaultValue": "a young woman with auburn hair",
      "kind": "text",
      "name": "subject"
    },
    {
      "allowedValues": [
        "melancholic",
        "joyful",
        "mysterious",
        "serene"
      ],
      "defaultValue": "melancholic",
      "kind": "enumeration",
      "name": "mood"
    }
  ],
  "version": 2,
  "community": {
    "author": {
      "name": "Gavin Schnee",
      "url": "https://x.com/Alaric4678"
    },
    "license": "CC-BY-4.0",
    "category": "photo"
  },
  "cover": {
    "format": "png",
    "dataBase64": ""
  },
  "sourceApp": "nyxastra-community"
}
